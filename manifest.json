{
  "manifest_version": 3,
  "name": "Remove YouTube Affiliate Overlay",
  "version": "1.0",
  "description": "Remove a tag yt-overlay-sticker do YouTube e notifica o usuário",
  "permissions": ["storage", "tabs"],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Stickers removidos",
    "default_icon": {
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
